{
    "packageName": "Python Filter Package",
    "authors": "Frederic Kerksieck",
    "date": "2023-09-06T13:18:24.308Z",
    "desc": "This package provides basic filters for the python programming language",
    "nodeFilterList": [
        {
            "name": "Class Filter Python",
            "regex": "/(?:class )([A-z]+)(?:\\((.*)\\))*:/gm",
            "id": "classFilterPython",
            "spec": "node",
            "excludes": null,
            "extension": ".py",
            "attributes": {
                "className": [1],
                "extends": [2]
            },
            "desc": "",
            "failures": [""],
            "tech-desc": "",
            "label": "Class",
            "labelAttribute": "className"
        },
        {
            "name": "Import Filter Python",
            "regex": "/(?:from ([\\w\\d]*) )?(?:import) ([\\w\\d]*(?:, [\\w\\d]*)*)/gm",
            "id": "importFilterPython",
            "spec": "node",
            "excludes": ["/(\\/\\/).*/gm", "/\\/(?!\\\\)\\*[\\s\\S]*?\\*(?!\\\\)\\//gm"],
            "extension": ".py",
            "attributes": {
                "from": [1],
                "import": [2]
            },
            "desc": "This filter finds python imports",
            "failures": ["this filter finds imports, but it can not differentiate between different imports made in the same line"],
            "tech-desc": "from is the project/library the import is from, import is the specific import",
            "label": "Import",
            "labelAttribute": "import"
        }
    ],
    "edgeFilterList": [
        {
            "allow-loop": true,
            "mode": "contains",
            "label": "extends",
            "spec": "edge",
            "id": "classEdgeFilterPython",
            "name": "Class-Edge Filter Python",
            "desc": "",
            "from": {
                "nodeFilterID": "classFilterPython",
                "attribute": "extends"
            },
            "to": {
                "nodeFilterID": "classFilterPython",
                "attribute": "className"
            },
            "style": {
                "dashes": false,
                "color": "#ff00ff"
            }
        }
    ]
}
