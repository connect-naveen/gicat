{
  "name": "GICAT",
  "version": "0.9.1",
  "description": "The GICAT visualizes the class structure of an object-oriented programmed software project. It shows the genealogy based on Git, as well as the software project's heredity of classes. For more information visit https://www.css-lab.rwth-aachen.de/tools/overview",
  "author": "CSS Lab RWTH Aachen",
  "private": true,
  "scripts": {
    "clean": "rm -rf node_modules/ dist/ dist_electron/",
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "test:unit": "vue-cli-service test:unit",
    "lint": "vue-cli-service lint",
    "lint:fix": "yarn eslint --fix",
    "electron:build": "vue-cli-service electron:build",
    "electron:serve": "vue-cli-service electron:serve",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder"
  },
  "dependencies": {
    "@electron/remote": "^2.0.10",
    "@mdi/font": "^7.3.67",
    "@mdi/js": "^7.3.67",
    "component-emitter": "^1.3.0",
    "core-js": "^3.8.3",
    "d3-force": "^3.0.0",
    "directory-tree": "^3.5.1",
    "pinia": "^2.1.7",
    "string.prototype.matchall": "^4.0.8",
    "v-network-graph": "^0.9.14",
    "vue": "^3.2.13",
    "vue-router": "^4.0.3",
    "vue3-visjs": "^0.7.2",
    "vuetify": "^3.3.8",
    "vuex": "^4.0.0",
    "webpack": "^5.0.0"
  },
  "resolutions": {
