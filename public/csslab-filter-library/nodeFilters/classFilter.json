{
  "id": "classFilter",
  "spec": "node",
  "name": "Class Filter",
  "extension": ".js",
  "regex": "/(?:(?:class\\s+)(?!extends)([\\w]+)(?:\\s+(?:extends)?\\s+)?([\\w]+)?)|([\\w]*)(?:\\s*\\=\\s*class)(?:\\s+extends\\s+)?([\\w]*)/gm",
  "attributes": {
    "className": [1, 3],
    "extends": [2, 4]
  },
  "mode": "contains",
  "excludes": ["/(\\/\\/).*/gm", "/\\/(?!\\\\)\\*[\\s\\S]*?\\*(?!\\\\)\\//gm"],
  "desc": "",
  "failures": [""],
  "tech-desc": "",
  "label": "Class",
  "labelAttribute": "className"
}